# ── Mute system ────────────────────────────────────────────────

def parse_duration(duration_str):
    units = {"s": 1, "m": 60, "h": 3600, "j": 86400, "d": 86400}
    unit = duration_str[-1].lower()
    if unit not in units:
        return None
    try:
        value = int(duration_str[:-1])
        return timedelta(seconds=value * units[unit])
    except ValueError:
        return None

@bot.command()
@bot_owner_or_permission(moderate_members=True)
async def mute(ctx, member: discord.Member = None, duration: str = None, *, reason: str = "Aucune raison fournie"):
    if member is None or duration is None:
        await ctx.send("❌ Utilisation : `!mute @utilisateur durée [raison]`\nExemples : `!mute @user 10m spam`, `!mute @user 1h flood`, `!mute @user 2j toxicité`\nUnités : `s` secondes, `m` minutes, `h` heures, `j` jours")
        return
    if member == ctx.author:
        await ctx.send("❌ Tu ne peux pas te mute toi-même !")
        return
    if member.bot:
        await ctx.send("❌ Tu ne peux pas mute un bot.")
        return
    delta = parse_duration(duration)
    if delta is None:
        await ctx.send("❌ Durée invalide. Exemples valides : `10m`, `1h`, `2j`, `30s`")
        return
    max_delta = timedelta(days=28)
    if delta > max_delta:
        await ctx.send("❌ La durée maximale de mute est de **28 jours**.")
        return
    until = datetime.now(timezone.utc) + delta
    await member.timeout(until, reason=reason)
    try:
        await member.send(
            f"🔇 Tu as été mis en sourdine sur **{ctx.guild.name}**.\n"
            f"**Durée :** {duration}\n"
            f"**Raison :** {reason}\n"
            f"**Par :** {ctx.author.name}"
        )
    except discord.Forbidden:
        pass
    await ctx.send(f"🔇 **{member.name}** a été mis en sourdine pendant **{duration}**. Raison : *{reason}*")

