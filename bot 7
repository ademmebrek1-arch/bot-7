@bot.command()
async def crash(ctx, bet: str = None):
    save_user_info(ctx.guild.id, ctx.author.id, ctx.author.display_name, str(ctx.author.display_avatar.url))
    balance = get_balance(ctx.guild.id, ctx.author.id)
    if bet is not None and bet.lower() == "all":
        bet = balance
    else:
        try:
            bet = int(bet)
        except (TypeError, ValueError):
            bet = None
    if bet is None or bet <= 0:
        await ctx.send("❌ Utilisation : `!crash <mise>` ou `!crash all` — ex: `!crash 200`\n💡 Tu as **2 secondes** pour cashout avant que la bombe explose !")
        return
    key = (ctx.guild.id, ctx.author.id)
    if key in active_crashes:
        await ctx.send("❌ Tu as déjà une partie Crash en cours ! Termine-la d'abord.")
        return
    if key in active_games:
        await ctx.send("❌ Tu as déjà une partie Mines en cours ! Termine-la d'abord.")
        return
    if bet > balance:
        await ctx.send(f"❌ Tu n'as que **{balance} coins**. Tu ne peux pas miser autant.")
        return
    update_balance(ctx.guild.id, ctx.author.id, -bet)
    crash_time = random.uniform(0.3, 2.0)
    game = {
        "bet": bet, "active": True, "cashed_out": False,
        "current_mult": 1.00, "crash_time": crash_time,
        "elapsed": 0.0, "payout": 0
    }
    active_crashes[key] = game
    view  = CrashView(game, ctx)
