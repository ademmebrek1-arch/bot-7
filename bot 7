@bot.command()
async def rob(ctx, member: discord.Member = None):
    if member is None:
        await ctx.send("❌ Utilisation : `!rob @user` — ex: `!rob @Naruto`")
        return
    if member.id == ctx.author.id:
        await ctx.send("❌ Tu ne peux pas te voler toi-même !")
        return
