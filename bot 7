            mins = int(remaining.total_seconds() // 60)
            secs = int(remaining.total_seconds() % 60)
            await ctx.send(f"⏳ Tu dois attendre encore **{mins}m {secs}s** avant de re-tenter un vol.")
            return
    save_user_info(ctx.guild.id, ctx.author.id, ctx.author.display_name, str(ctx.author.display_avatar.url))
    save_user_info(ctx.guild.id, member.id, member.display_name, str(member.display_avatar.url))
    target_bal = get_balance(ctx.guild.id, member.id)
    if target_bal < ROB_MIN_TARGET_BAL:
        await ctx.send(f"❌ {member.display_name} n'a que **{target_bal} coins** — trop pauvre pour être volé (minimum {ROB_MIN_TARGET_BAL}).")
        return
    rob_cooldowns[ctx.author.id] = now
    if random.random() < ROB_SUCCESS_RATE:
        steal_pct   = random.uniform(ROB_MIN_STEAL, ROB_MAX_STEAL)
        stolen      = max(1, int(target_bal * steal_pct))
        new_target  = update_balance(ctx.guild.id, member.id, -stolen)
        new_robber  = update_balance(ctx.guild.id, ctx.author.id, stolen)
        embed = discord.Embed(
            title="🦹 Vol réussi !",
            color=discord.Color.dark_green()
        )
        embed.add_field(name="💰 Volé",           value=f"**{stolen} coins** ({int(steal_pct*100)}% du solde)",    inline=True)
        embed.add_field(name="📤 Victime",         value=f"{member.mention} → **{new_target} coins**",             inline=True)
        embed.add_field(name="📥 Ton nouveau solde", value=f"**{new_robber} coins**",                              inline=False)
        embed.set_footer(text=f"🕐 Prochain vol disponible dans {ROB_COOLDOWN_MINUTES} minutes.")
    else:
        robber_bal  = get_balance(ctx.guild.id, ctx.author.id)
        fine        = max(1, int(robber_bal * ROB_FINE_RATE))
        new_robber  = update_balance(ctx.guild.id, ctx.author.id, -fine)
        embed = discord.Embed(
            title="🚨 Vol raté ! Amende !",
            color=discord.Color.red()
        )
        embed.add_field(name="💸 Amende",          value=f"**-{fine} coins** (15% de ton solde)",                  inline=True)
        embed.add_field(name="📉 Ton nouveau solde", value=f"**{new_robber} coins**",                              inline=True)
        embed.add_field(name="🔒 Victime",          value=f"{member.mention} n'a rien perdu.",                     inline=False)
        embed.set_footer(text=f"😤 Tu t'es fait attraper ! Reviens dans {ROB_COOLDOWN_MINUTES} minutes.")
    await ctx.send(embed=embed)

