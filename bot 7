@bot.event
async def on_message(message):
    if message.author.bot or not message.guild:
        await bot.process_commands(message)
        return
    gid = message.guild.id
    uid = message.author.id
    key = (gid, uid)
    content = message.content.strip().lower()
    if not content:
        await bot.process_commands(message)
        return
    now = datetime.now(timezone.utc)
    history = spam_log.setdefault(key, [])
    history.append((content, now))
    spam_log[key] = [(c, t) for c, t in history if (now - t).total_seconds() <= SPAM_WINDOW]
    same = [c for c, t in spam_log[key] if c == content]
    if len(same) >= SPAM_LIMIT and antiraid_enabled.get(gid, False):
        spam_log[key] = []
        try:
            await message.author.send(
                f"🚫 Tu as été **banni automatiquement** de **{message.guild.name}** "
                f"pour spam répétitif ({SPAM_LIMIT} messages identiques en {SPAM_WINDOW}s)."
            )
        except discord.Forbidden:
            pass
        await message.author.ban(reason=f"Anti-spam : {SPAM_LIMIT} messages identiques en {SPAM_WINDOW}s")
        channel = message.channel
        embed = discord.Embed(
            title="🚫 Anti-Spam — Ban automatique",
            description=(
                f"**{message.author.name}** a été **banni** automatiquement.\n"
                f"**Raison :** {SPAM_LIMIT} messages identiques en moins de {SPAM_WINDOW} secondes.\n"
                f"**Message :** `{message.content[:100]}`"
            ),
            color=discord.Color.red()
        )
        await channel.send(embed=embed)
        return
    await add_xp(message.guild.id, message.author.id, message.author)
    await bot.process_commands(message)

@bot.event
async def on_member_join(member):
    guild = member.guild
    gid = guild.id
    # ── Message de bienvenue ────────────────────────────────────
    welcome_data = load_welcome()
    wch_id = welcome_data.get(str(gid))
    if wch_id:
        wch = guild.get_channel(int(wch_id))
        if wch:
            embed = discord.Embed(
                title=f"👋 Bienvenue sur {guild.name} !",
                description=(
                    f"Salut {member.mention}, on est content de t'avoir parmi nous ! 🔥\n\n"
                    f"Tu es le **{guild.member_count}ème membre** du serveur."
                ),
                color=discord.Color.blurple()
            )
            embed.set_thumbnail(url=member.display_avatar.url)
            embed.set_footer(text=f"Rejoins le {member.joined_at.strftime('%d/%m/%Y à %H:%M') if member.joined_at else ''}")
            try:
                await wch.send(embed=embed)
            except discord.Forbidden:
                pass
    # ── Anti-raid ───────────────────────────────────────────────
    if not antiraid_enabled.get(gid, False):
        return
    now = datetime.now(timezone.utc)
    joins = join_log.setdefault(gid, [])
    joins.append(now)
    join_log[gid] = [t for t in joins if (now - t).total_seconds() <= RAID_WINDOW]
    if len(join_log[gid]) >= RAID_THRESHOLD and not raid_active.get(gid, False):
        raid_active[gid] = True
        channel = guild.system_channel or next(
            (c for c in guild.text_channels if c.permissions_for(guild.me).send_messages), None
        )
        recent_joins = [t for t in join_log[gid]]
        join_log[gid] = []
        kicked = 0
        for m in list(guild.members):
            if m.bot or m == guild.me:
                continue
            joined = m.joined_at
            if joined and any(abs((joined - t).total_seconds()) <= RAID_WINDOW for t in recent_joins):
                try:
                    await m.kick(reason="🚨 Anti-raid : kick automatique")
                    kicked += 1
                except discord.Forbidden:
                    pass
        for ch in guild.text_channels:
            try:
                ow = ch.overwrites_for(guild.default_role)
                ow.send_messages = False
                await ch.set_permissions(guild.default_role, overwrite=ow)
            except discord.Forbidden:
                pass
        if channel:
            embed = discord.Embed(
                title="🚨 RAID DÉTECTÉ — Protection activée",
                description=(
                    f"**{len(recent_joins)} membres** ont rejoint en moins de **{RAID_WINDOW} secondes**.\n\n"
                    f"✅ **{kicked} membre(s) kické(s)** automatiquement.\n"
                    f"🔒 **Tous les salons verrouillés.**\n\n"
                    f"Utilise `!antiraid off` puis `!unlock` dans chaque salon quand c'est calme."
                ),
                color=discord.Color.red()
            )
            await channel.send(embed=embed)
        await asyncio.sleep(30)
        raid_active[gid] = False

@bot.event
async def on_member_ban(guild, user):
    await asyncio.sleep(2)
    try:
        async for entry in guild.audit_logs(action=discord.AuditLogAction.ban, limit=5):
            if entry.target.id == user.id:
                if not entry.reason:
                    banner = guild.get_member(entry.user.id)
                    if banner and banner != guild.me:
                        channel = guild.system_channel or next(
                            (c for c in guild.text_channels if c.permissions_for(guild.me).send_messages),
                            None
                        )
                        await derank_member(guild, banner, channel)
                break
    except discord.Forbidden:
        pass

