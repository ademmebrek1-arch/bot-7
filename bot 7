    message = await ctx.send(embed=embed, view=view)
    interval = 0.25
    while game["active"] and game["elapsed"] < crash_time:
        await asyncio.sleep(interval)
        if not game["active"]:
            break
        game["elapsed"] += interval
        game["current_mult"] = round(1.0 + game["elapsed"] * 4.5, 2)
        try:
            await message.edit(embed=build_crash_embed(game, "running"), view=view)
        except Exception:
            break
    if game["active"]:
        game["active"] = False
        active_crashes.pop(key, None)
        for item in view.children:
            item.disabled = True
        try:
