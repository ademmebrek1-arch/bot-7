TOTAL_CELLS  = 20
NUM_BOMBS    = 3
MULTIPLIERS  = [1.0, 1.12, 1.33, 1.59, 1.92, 2.35, 2.92,
                3.68, 4.73, 6.20, 8.30, 11.5, 16.5, 24.0,
                36.0, 56.0, 92.0, 175.0]
active_games = {}  # {(guild_id, user_id): game_state}

def build_mines_embed(game, title="💎 Mines", color=discord.Color.blurple()):
    safe   = game["safe_count"]
    mult   = MULTIPLIERS[min(safe, len(MULTIPLIERS) - 1)]
    payout = int(game["bet"] * mult)
    embed = discord.Embed(title=title, color=color)
    embed.add_field(name="💰 Mise",             value=f"{game['bet']} coins", inline=True)
    embed.add_field(name="✅ Cases sûres",       value=str(safe),             inline=True)
    embed.add_field(name="📈 Multiplicateur",    value=f"{mult}x",            inline=True)
    embed.add_field(name="💵 Gain potentiel",    value=f"{payout} coins",     inline=True)
    embed.add_field(name="💣 Bombes restantes",  value=str(NUM_BOMBS),        inline=True)
    embed.set_footer(text="Clique une case ou cashout !")
    return embed

class MinesView(discord.ui.View):
    def __init__(self, game, ctx):
        super().__init__(timeout=180)
        self.game = game
        self.ctx  = ctx
        self._build()

    def _build(self):
        self.clear_items()
        for i in range(TOTAL_CELLS):
            revealed = self.game["revealed"][i]
            is_bomb  = self.game["grid"][i]
            if not revealed:
                btn = discord.ui.Button(
                    label="⬜", style=discord.ButtonStyle.secondary,
                    custom_id=f"cell_{i}", row=i // 5
                )
                btn.callback = self._make_cb(i)
            elif is_bomb:
                btn = discord.ui.Button(
                    label="💣", style=discord.ButtonStyle.danger,
                    disabled=True, row=i // 5
                )
            else:
                btn = discord.ui.Button(
                    label="💎", style=discord.ButtonStyle.success,
                    disabled=True, row=i // 5
                )
            self.add_item(btn)

        if self.game["safe_count"] > 0 and self.game["active"]:
            mult   = MULTIPLIERS[min(self.game["safe_count"], len(MULTIPLIERS) - 1)]
            payout = int(self.game["bet"] * mult)
            cash_btn = discord.ui.Button(
                label=f"💰 Cashout — {payout} coins",
                style=discord.ButtonStyle.primary,
                custom_id="cashout", row=4
            )
            cash_btn.callback = self._cashout_cb
            self.add_item(cash_btn)

    def _make_cb(self, index):
        async def callback(interaction: discord.Interaction):
            if interaction.user.id != self.ctx.author.id:
                await interaction.response.send_message("❌ Ce n'est pas ton jeu !", ephemeral=True)
                return
            if not self.game["active"]:
                await interaction.response.send_message("❌ Ce jeu est déjà terminé.", ephemeral=True)
                return
            self.game["revealed"][index] = True
            if self.game["grid"][index]:
                self.game["active"] = False
                for i, bomb in enumerate(self.game["grid"]):
                    if bomb:
                        self.game["revealed"][i] = True
                self._build()
                for item in self.children:
                    item.disabled = True
                active_games.pop((self.ctx.guild.id, self.ctx.author.id), None)
                embed = build_mines_embed(self.game, "💣 BOOM ! Bombe touchée !", discord.Color.red())
                bal = get_balance(self.ctx.guild.id, self.ctx.author.id)
                embed.add_field(name="❌ Perdu", value=f"{self.game['bet']} coins perdus\n💰 Solde : {bal} coins", inline=False)
                await interaction.response.edit_message(embed=embed, view=self)
            else:
                self.game["safe_count"] += 1
                remaining = TOTAL_CELLS - sum(self.game["revealed"])
                self._build()
                if remaining == 0 or self.game["safe_count"] == TOTAL_CELLS - NUM_BOMBS:
                    await self._auto_cashout(interaction)
                    return
                embed = build_mines_embed(self.game)
                await interaction.response.edit_message(embed=embed, view=self)
        return callback

    async def _cashout_cb(self, interaction: discord.Interaction):
        if interaction.user.id != self.ctx.author.id:
            await interaction.response.send_message("❌ Ce n'est pas ton jeu !", ephemeral=True)
            return
        await self._do_cashout(interaction)

    async def _auto_cashout(self, interaction):
        await self._do_cashout(interaction, auto=True)

    async def _do_cashout(self, interaction, auto=False):
        self.game["active"] = False
        mult    = MULTIPLIERS[min(self.game["safe_count"], len(MULTIPLIERS) - 1)]
        payout  = int(self.game["bet"] * mult)
        new_bal = update_balance(self.ctx.guild.id, self.ctx.author.id, payout)
        for i, bomb in enumerate(self.game["grid"]):
            if bomb:
                self.game["revealed"][i] = True
        self._build()
        for item in self.children:
            item.disabled = True
        active_games.pop((self.ctx.guild.id, self.ctx.author.id), None)
        title = "🏆 Toutes les cases trouvées !" if auto else "💰 Cashout !"
        embed = build_mines_embed(self.game, title, discord.Color.gold())
        embed.add_field(
            name="✅ Gagné",
            value=f"**+{payout} coins** (x{mult})\n💰 Nouveau solde : {new_bal} coins",
            inline=False
        )
        await interaction.response.edit_message(embed=embed, view=self)

    async def on_timeout(self):
        active_games.pop((self.ctx.guild.id, self.ctx.author.id), None)

