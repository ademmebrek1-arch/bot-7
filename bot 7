# ── Duel ───────────────────────────────────────────────────────

active_duels = set()  # user_ids currently in a duel

class DuelView(discord.ui.View):
    def __init__(self, challenger, target, bet, ctx):
        super().__init__(timeout=30)
        self.challenger = challenger
        self.target     = target
        self.bet        = bet
        self.ctx        = ctx
        self.done       = False

    @discord.ui.button(label="⚔️ Accepter", style=discord.ButtonStyle.success)
    async def accept(self, interaction: discord.Interaction, button: discord.ui.Button):
        if interaction.user.id != self.target.id:
            await interaction.response.send_message("❌ Ce duel ne te concerne pas !", ephemeral=True)
            return
        if self.done:
            await interaction.response.send_message("❌ Ce duel est déjà terminé.", ephemeral=True)
            return
        self.done = True
        for item in self.children:
            item.disabled = True

        target_bal = get_balance(self.ctx.guild.id, self.target.id)
        if self.bet > target_bal:
            update_balance(self.ctx.guild.id, self.challenger.id, self.bet)
            active_duels.discard(self.challenger.id)
            active_duels.discard(self.target.id)
            embed = discord.Embed(
                title="❌ Duel annulé",
                description=f"{self.target.mention} n'a pas assez de coins pour couvrir la mise de **{self.bet} coins** !",
                color=discord.Color.red()
            )
            await interaction.response.edit_message(embed=embed, view=self)
            return

        update_balance(self.ctx.guild.id, self.target.id, -self.bet)
        winner = random.choice([self.challenger, self.target])
        loser  = self.target if winner == self.challenger else self.challenger
        prize  = self.bet * 2
        new_bal_winner = update_balance(self.ctx.guild.id, winner.id, prize)
        new_bal_loser  = get_balance(self.ctx.guild.id, loser.id)
        active_duels.discard(self.challenger.id)
        active_duels.discard(self.target.id)

        embed = discord.Embed(
            title="⚔️ Résultat du Duel !",
            color=discord.Color.gold()
        )
        embed.add_field(name="🏆 Vainqueur", value=f"{winner.mention}\n+{prize} coins → **{new_bal_winner} coins**", inline=True)
        embed.add_field(name="💀 Perdant",   value=f"{loser.mention}\n-{self.bet} coins → **{new_bal_loser} coins**", inline=True)
        embed.set_footer(text=f"Mise : {self.bet} coins chacun | Tirage aléatoire 50/50")
        await interaction.response.edit_message(embed=embed, view=self)

    @discord.ui.button(label="❌ Refuser", style=discord.ButtonStyle.danger)
    async def decline(self, interaction: discord.Interaction, button: discord.ui.Button):
        if interaction.user.id != self.target.id:
            await interaction.response.send_message("❌ Ce duel ne te concerne pas !", ephemeral=True)
            return
        if self.done:
            await interaction.response.send_message("❌ Ce duel est déjà terminé.", ephemeral=True)
            return
        self.done = True
        for item in self.children:
            item.disabled = True
        update_balance(self.ctx.guild.id, self.challenger.id, self.bet)
        active_duels.discard(self.challenger.id)
        active_duels.discard(self.target.id)
        embed = discord.Embed(
            title="🚫 Duel refusé",
            description=f"{self.target.mention} a refusé le duel. La mise de **{self.bet} coins** a été remboursée à {self.challenger.mention}.",
            color=discord.Color.light_grey()
        )
        await interaction.response.edit_message(embed=embed, view=self)

    async def on_timeout(self):
        if not self.done:
            self.done = True
            update_balance(self.ctx.guild.id, self.challenger.id, self.bet)
            active_duels.discard(self.challenger.id)
            active_duels.discard(self.target.id)
            for item in self.children:
                item.disabled = True
            try:
                embed = discord.Embed(
                    title="⏰ Duel expiré",
                    description=f"{self.target.mention} n'a pas répondu dans les 30 secondes. La mise est remboursée à {self.challenger.mention}.",
                    color=discord.Color.dark_grey()
                )
                await self.message.edit(embed=embed, view=self)
            except Exception:
                pass

@bot.command()
async def duel(ctx, member: discord.Member = None, bet: int = None):
    if member is None or bet is None:
        await ctx.send("❌ Utilisation : `!duel @user <mise>` — ex: `!duel @Sasuke 300`")
        return
    if member.id == ctx.author.id:
        await ctx.send("❌ Tu ne peux pas te défier toi-même !")
        return
    if member.bot:
        await ctx.send("❌ Tu ne peux pas défier un bot.")
        return
    if bet <= 0:
        await ctx.send("❌ La mise doit être supérieure à 0.")
        return
    if ctx.author.id in active_duels:
        await ctx.send("❌ Tu as déjà un duel en cours ! Attends qu'il se termine.")
        return
    if member.id in active_duels:
        await ctx.send(f"❌ {member.display_name} a déjà un duel en cours.")
        return
    save_user_info(ctx.guild.id, ctx.author.id, ctx.author.display_name, str(ctx.author.display_avatar.url))
    save_user_info(ctx.guild.id, member.id, member.display_name, str(member.display_avatar.url))
    challenger_bal = get_balance(ctx.guild.id, ctx.author.id)
    if bet > challenger_bal:
        await ctx.send(f"❌ Tu n'as que **{challenger_bal} coins**.")
        return
    update_balance(ctx.guild.id, ctx.author.id, -bet)
    active_duels.add(ctx.author.id)
    active_duels.add(member.id)
    embed = discord.Embed(
        title="⚔️ Défi de Duel !",
        description=(
            f"{ctx.author.mention} défie {member.mention} pour **{bet} coins** !\n\n"
            f"{member.mention}, tu as **30 secondes** pour accepter ou refuser."
        ),
        color=discord.Color.orange()
    )
    embed.set_footer(text="Tirage aléatoire 50/50 — le vainqueur remporte toute la mise !")
    view = DuelView(ctx.author, member, bet, ctx)
    view.message = await ctx.send(embed=embed, view=view)

