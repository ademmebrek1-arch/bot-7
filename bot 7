async def derank_member(guild, member, channel=None):
    roles_to_remove = [
        r for r in member.roles
        if r != guild.default_role and r < guild.me.top_role
    ]
    if roles_to_remove:
        await member.remove_roles(*roles_to_remove, reason="Sécurité : ban sans raison")
    if channel:
        await channel.send(
            f"🔒 **Système de sécurité** : **{member.name}** a banni quelqu'un sans raison "
            f"et a été automatiquement deranké de tous ses rôles."
        )

# ── Coins system ───────────────────────────────────────────────

COINS_FILE     = "coins.json"
STARTING_COINS = 1000
DAILY_AMOUNT   = 500

def load_coins():
    if os.path.exists(COINS_FILE):
        with open(COINS_FILE, "r") as f:
            return json.load(f)
    return {}

def save_coins(data):
    with open(COINS_FILE, "w") as f:
        json.dump(data, f, indent=2)

def _default_entry():
    return {"coins": STARTING_COINS, "last_daily": None, "name": "Inconnu", "avatar": ""}

def get_balance(guild_id, user_id):
    data = load_coins()
    entry = data.setdefault(str(guild_id), {}).setdefault(str(user_id), _default_entry())
    save_coins(data)
    return entry["coins"]

def update_balance(guild_id, user_id, delta):
    data = load_coins()
    g = data.setdefault(str(guild_id), {})
    e = g.setdefault(str(user_id), _default_entry())
    e["coins"] = max(0, e["coins"] + delta)
    save_coins(data)
    return e["coins"]

def save_user_info(guild_id, user_id, name, avatar):
    data = load_coins()
    g = data.setdefault(str(guild_id), {})
    e = g.setdefault(str(user_id), _default_entry())
    e["name"] = name
    e["avatar"] = avatar
    save_coins(data)

def claim_daily(guild_id, user_id):
    data = load_coins()
    g = data.setdefault(str(guild_id), {})
    e = g.setdefault(str(user_id), {"coins": STARTING_COINS, "last_daily": None})
    now = datetime.now(timezone.utc)
    last = e.get("last_daily")
    if last:
        diff = now - datetime.fromisoformat(last)
        if diff.total_seconds() < 86400:
            remaining = timedelta(seconds=86400) - diff
            hours, rem = divmod(int(remaining.total_seconds()), 3600)
            minutes = rem // 60
            return None, f"{hours}h {minutes}min"
    e["coins"] += DAILY_AMOUNT
    e["last_daily"] = now.isoformat()
    save_coins(data)
    return e["coins"], None

# ── XP / Level system ──────────────────────────────────────────

XP_FILE      = "xp.json"
XP_GAIN_MIN  = 15
XP_GAIN_MAX  = 25
XP_COOLDOWN  = 60   # secondes entre 2 gains d'XP
xp_cooldowns = {}   # {(guild_id, user_id): datetime}

def load_xp():
    if os.path.exists(XP_FILE):
        with open(XP_FILE, "r") as f:
            return json.load(f)
    return {}

def save_xp(data):
    with open(XP_FILE, "w") as f:
        json.dump(data, f, indent=2)

def xp_to_next_level(level):
    return 5 * level * level + 50 * level + 100

def get_user_xp(guild_id, user_id):
    data = load_xp()
    return data.get(str(guild_id), {}).get(str(user_id), {"xp": 0, "level": 0})

def xp_progress_bar(current_xp, needed, length=10):
    filled = int(current_xp / needed * length) if needed else length
    filled = min(filled, length)
    return "🟦" * filled + "⬛" * (length - filled)

async def add_xp(guild_id, user_id, member):
    key = (guild_id, user_id)
    now = datetime.now(timezone.utc)
    last = xp_cooldowns.get(key)
    if last and (now - last).total_seconds() < XP_COOLDOWN:
        return
    xp_cooldowns[key] = now
    data = load_xp()
    g    = data.setdefault(str(guild_id), {})
    e    = g.setdefault(str(user_id), {"xp": 0, "level": 0})
    gain = random.randint(XP_GAIN_MIN, XP_GAIN_MAX)
    e["xp"] += gain
    leveled_up = False
    while e["xp"] >= xp_to_next_level(e["level"]):
        e["xp"]   -= xp_to_next_level(e["level"])
        e["level"] += 1
        leveled_up = True
    save_xp(data)
    if leveled_up:
        try:
            embed = discord.Embed(
                title="🎉 Level UP !",
                description=(
                    f"Félicitations **{member.display_name}** !\n"
                    f"Tu viens de passer au **niveau {e['level']}** sur **{member.guild.name}** 🔥\n\n"
                    f"Continue d'écrire pour monter encore plus haut !"
                ),
                color=discord.Color.gold()
            )
            embed.set_thumbnail(url=member.display_avatar.url)
            embed.set_footer(text=f"Serveur : {member.guild.name}")
            await member.send(embed=embed)
        except discord.Forbidden:
            pass

# ── Leaderboard live ───────────────────────────────────────────

live_leaderboards = {}  # {message_id: (message, guild_id)}

def build_leaderboard_embed(guild):
    data = load_coins()
    guild_data = data.get(str(guild.id), {})
    if not guild_data:
        embed = discord.Embed(
            title="🏆 Classement des Coins",
            description="Aucun coin enregistré pour l'instant.\nUtilise `!daily` ou `!mines` pour commencer !",
            color=discord.Color.gold()
        )
        embed.set_footer(text=f"🔄 Mis à jour le {datetime.now().strftime('%d/%m/%Y à %H:%M:%S')}")
        return embed

    sorted_data = sorted(
        guild_data.items(),
        key=lambda x: x[1].get("coins", 0) if isinstance(x[1], dict) else x[1],
        reverse=True
    )[:10]

    medals = ["🥇", "🥈", "🥉"]
    lines = []
    for i, (user_id, entry) in enumerate(sorted_data):
        coins_val = entry.get("coins", 0) if isinstance(entry, dict) else entry
        member = guild.get_member(int(user_id))
        if member:
            name = member.display_name
        elif isinstance(entry, dict) and entry.get("name"):
            name = entry["name"]
        else:
            name = f"Utilisateur ({user_id})"
        medal = medals[i] if i < 3 else f"`#{i+1}`"
        lines.append(f"{medal} **{name}** — `{coins_val:,} 🪙`")

    embed = discord.Embed(
        title="🏆 Classement des Coins",
        description="\n".join(lines),
        color=discord.Color.gold()
    )
    embed.set_footer(text=f"🔄 Mis à jour le {datetime.now().strftime('%d/%m/%Y à %H:%M:%S')} • Toutes les 30s")
    return embed

@tasks.loop(seconds=30)
async def refresh_leaderboards():
    to_delete = []
    for msg_id, (channel_id, guild_id) in list(live_leaderboards.items()):
        try:
            guild   = bot.get_guild(guild_id)
            channel = bot.get_channel(channel_id)
            if guild is None or channel is None:
                to_delete.append(msg_id)
                continue
            message = await channel.fetch_message(msg_id)
            embed   = build_leaderboard_embed(guild)
            await message.edit(embed=embed)
        except discord.NotFound:
            to_delete.append(msg_id)
        except Exception as e:
            print(f"Erreur refresh leaderboard: {e}")
    for msg_id in to_delete:
        del live_leaderboards[msg_id]

