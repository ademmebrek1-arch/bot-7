# ── Start avec reconnexion automatique ─────────────────────────

import sys

async def launch():
    raw = os.environ.get("DISCORD_TOKEN", "")
    token = raw.strip()
    if not token:
        print("❌  DISCORD_TOKEN manquant. Ajoutez-le dans les Secrets.")
        sys.exit(1)
    print("🔄  Démarrage du bot...")
    try:
        async with bot:
            await bot.start(token, reconnect=True)
        print("✅  Bot arrêté proprement.")
    except discord.errors.LoginFailure as e:
        print(f"❌  Token refusé par Discord : {e}")
        print("    → Allez sur discord.com/developers → Bot → Reset Token")
        sys.exit(1)
    except Exception as e:
        print(f"⚠️  Crash : {type(e).__name__}: {e}")
        print("⏳  Redémarrage dans 5s...")
        import time; time.sleep(5)
        os.execv(sys.executable, [sys.executable] + sys.argv)

asyncio.run(launch())
